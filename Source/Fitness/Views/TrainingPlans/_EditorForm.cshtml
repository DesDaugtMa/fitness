<div class="container-xl py-4 pb-5 mb-5">
    <form id="trainingPlanForm" class="needs-validation" novalidate onsubmit="return false;">
        
        <div class="row">
            <!-- Sidebar (Links auf PC, oben auf Mobile) -->
            <div class="col-12 col-lg-4 col-xl-3 mb-4">
                <div class="sticky-sidebar">
                    <!-- Training Plan Info Card -->
                    <div class="card shadow-sm mb-4 border-0">
                        <div class="card-body p-4">
                            <div class="mb-3">
                                <label for="planName" class="form-label fw-bold">Name des Trainingsplans</label>
                                <input type="text" class="form-control form-control-lg" id="planName" placeholder="z.B. 4er Split Hypertrophie" required>
                                <div class="invalid-feedback">Bitte gib dem Trainingsplan einen Namen.</div>
                            </div>
                            <div class="mb-0">
                                <label for="planDesc" class="form-label fw-bold">Beschreibung <span class="text-muted fw-normal">(Optional)</span></label>
                                <textarea class="form-control" id="planDesc" rows="2" placeholder="Kurze Beschreibung deines Plans..."></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Horizontal Tabs for Days / Vertical Sidebar on PC -->
                    <h6 class="fw-bold d-none d-lg-block mb-3 ms-2">Trainingstage</h6>
                    <ul id="dayTabsContainer" class="nav nav-pills flex-nowrap flex-lg-column gap-2 mb-4 pb-2 pb-lg-0" role="tablist">
                        <!-- Tab Buttons will be inserted dynamically here -->
                    </ul>
                </div>
            </div>

            <!-- Days Container (Main Content) -->
            <div class="col-12 col-lg-8 col-xl-9">
                <div id="daysContainer" class="mb-4">
                    <!-- Tage werden hier dynamisch per JS eingefügt -->
                </div>
            </div>
        </div>

        <template id="dayTemplate">
            <div class="card mb-4 shadow-sm border-0 plan-card day-card" data-day-id="">
                <div class="card-header bg-transparent border-bottom pt-3 pb-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="flex-grow-1 me-3 position-relative day-name-wrapper">
                            <input type="text" class="form-control form-control-lg fw-bold border-0 bg-transparent px-2 day-name-input pe-4" placeholder="Name des Tages" required>
                            <i class="bi bi-pencil-fill position-absolute text-muted edit-icon" style="right: 10px; top: 50%; transform: translateY(-50%); pointer-events: none; opacity: 0.5;"></i>
                            <div class="invalid-feedback px-2">Bitte gib dem Tag einen Namen.</div>
                        </div>
                    </div>
                    <div class="form-check form-switch form-check-switch-lg pt-1 pb-1 px-2 mb-0 d-flex align-items-center">
                        <input class="form-check-input restday-toggle m-0 flex-shrink-0" type="checkbox" role="switch">
                        <label class="form-check-label ms-2 text-muted" style="font-size: 0.85rem;">Restday</label>
                    </div>
                </div>
                <div class="card-body day-content">
                    <!-- Übungsliste (SortableJS Container) für diesen Tag -->
                    <div class="day-exercises-list list-group min-vh-25 mb-4">
                        <!-- Übungen werden hier eingefügt -->
                    </div>

                    <!-- Leerer Status für den Tag -->
                    <div class="day-empty-state text-center p-3 mb-4 rounded-3 text-muted" style="background-color: var(--empty-bg);">
                        <i class="bi bi-card-list fs-3 mb-1 d-block text-secondary opacity-50"></i>
                        <small>Keine Übungen an diesem Tag.</small>
                    </div>

                    <label class="form-label fw-bold mb-2">Weitere Übung hinzufügen</label>
                    <div class="mb-2">
                        <select class="form-control day-exercise-select">
                            <option value="">Wähle eine Übung...</option>
                        </select>
                    </div>
                </div>
            </div>
        </template>
    </form>
</div>

<!-- Save Bottom Bar -->
<div class="fixed-bottom border-top shadow-lg py-3 save-bottom-bar" style="z-index: 1040;">
    <div class="container-xl">
        <div class="row">
            <div class="col-12 d-flex flex-column flex-lg-row justify-content-lg-end align-items-center">
                <div id="globalError" class="text-danger small fw-bold d-none mb-3 mb-lg-0 me-lg-4 text-center text-lg-end w-100" style="max-width: 500px;"></div>
                <button type="submit" form="trainingPlanForm" class="btn btn-primary btn-lg shadow-sm w-100" id="savePlanBtn" style="max-width: 350px;">
                    <i class="bi bi-save me-2"></i>Plan speichern & beenden
                </button>
            </div>
        </div>
    </div>
</div>
